# ============================================
# INVENTORY MANAGEMENT SYSTEM - ENVIRONMENT VARIABLES
# ============================================

# ---------------------------------------------
# APPLICATION SETTINGS
# ---------------------------------------------
NODE_ENV=development
PORT=5000

# ---------------------------------------------
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ---------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_DB_PASSWORD=your-database-password-here

# Database Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_IDLE_TIMEOUT=30000
DB_ACQUIRE_TIMEOUT=60000

# ---------------------------------------------
# JWT AUTHENTICATION
# ---------------------------------------------
# IMPORTANT: Change these secrets in production!
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-strong-refresh-secret-here-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------------------------
# ENCRYPTION
# ---------------------------------------------
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=change-this-32-character-key-now

# ---------------------------------------------
# CORS CONFIGURATION
# ---------------------------------------------
CORS_ORIGIN=*
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5000

# ---------------------------------------------
# RATE LIMITING
# ---------------------------------------------
# General API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication endpoints rate limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ---------------------------------------------
# LOGGING
# ---------------------------------------------
# Options: error, warn, info, http, debug
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ---------------------------------------------
# SECURITY SETTINGS
# ---------------------------------------------
# Bcrypt salt rounds (10-12 recommended for production)
BCRYPT_SALT_ROUNDS=10

# Account lockout settings
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=120

# Minimum password length
MIN_PASSWORD_LENGTH=8

# ---------------------------------------------
# EMAIL CONFIGURATION (Optional)
# ---------------------------------------------
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@inventory.com

# ---------------------------------------------
# FILE UPLOAD SETTINGS
# ---------------------------------------------
# Max file size in bytes (10MB = 10485760)
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# ---------------------------------------------
# FRONTEND/BACKEND URLS
# ---------------------------------------------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ---------------------------------------------
# PAGINATION
# ---------------------------------------------
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# ---------------------------------------------
# BUSINESS LOGIC SETTINGS
# ---------------------------------------------
# Invoice and expense number prefixes
INVOICE_NUMBER_PREFIX=INV
EXPENSE_NUMBER_PREFIX=EXP

# Subscription settings
TRIAL_PERIOD_DAYS=14
SUBSCRIPTION_GRACE_PERIOD_DAYS=7

# VIP customer threshold (in currency units)
VIP_THRESHOLD=1000

# Low stock warning threshold percentage
LOW_STOCK_THRESHOLD_PERCENTAGE=20

# ---------------------------------------------
# TIMEZONE
# ---------------------------------------------
TIMEZONE=UTC


# ---------------------------------------------
# PAYMENT INTEGRATION
# ---------------------------------------------

# Stripe (Optional)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# MaxiCash (Required for subscription payments)
# Get credentials from: https://developer.maxicashapp.com/
# Environment: sandbox or live
MAXICASH_MERCHANT_ID=your_maxicash_merchant_id
MAXICASH_MERCHANT_PASSWORD=your_maxicash_merchant_password
MAXICASH_ENVIRONMENT=sandbox

# ---------------------------------------------
# NOTIFICATION SERVICES (Optional)
# ---------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ---------------------------------------------
# ANALYTICS (Optional)
# ---------------------------------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
SENTRY_DSN=https://your-sentry-dsn

# ---------------------------------------------
# FEATURE FLAGS
# ---------------------------------------------
ENABLE_SUBSCRIPTION_CHECKS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_AUDIT_LOGS=true
ENABLE_ADVANCED_REPORTING=true

# ---------------------------------------------
# CACHE SETTINGS (Optional)
# ---------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL_SECONDS=3600

# ---------------------------------------------
# BACKUP SETTINGS
# ---------------------------------------------
AUTO_BACKUP_ENABLED=false
BACKUP_SCHEDULE_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ---------------------------------------------
# DATA CLEANUP SETTINGS
# ---------------------------------------------
# Automatically delete old invoices to free up storage space
# Only deletes invoices with status: paid, cancelled, or refunded (for safety)
INVOICE_CLEANUP_ENABLED=true
# Delete invoices older than this many days (default: 140 days)
INVOICE_CLEANUP_DAYS=140
# Run cleanup every X hours (default: 24 hours = daily)
INVOICE_CLEANUP_INTERVAL_HOURS=24

# ---------------------------------------------
# DEVELOPMENT TOOLS
# ---------------------------------------------
# Enable detailed debug logging
DEBUG=false

# Enable API request/response logging
LOG_API_REQUESTS=true

# Enable SQL query logging
LOG_SQL_QUERIES=false

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true
