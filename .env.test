# ============================================
# TEST ENVIRONMENT VARIABLES
# ============================================

NODE_ENV=test
PORT=5001

# Test Database (Use a separate test database!)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventory_management_test
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=5
DB_IDLE_TIMEOUT=10000
DB_ACQUIRE_TIMEOUT=30000

# JWT (Use different secrets for testing)
JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-production
JWT_REFRESH_EXPIRES_IN=1d

# Encryption
ENCRYPTION_KEY=test-encryption-key-32-chars!

# CORS
CORS_ORIGIN=*
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting (More lenient for tests)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=100

# Logging (Minimal for tests)
LOG_LEVEL=error
LOG_FILE_PATH=./logs/test

# Security
BCRYPT_SALT_ROUNDS=4
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=5
SESSION_TIMEOUT_MINUTES=30
MIN_PASSWORD_LENGTH=6

# Email (Disabled in tests)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=test@example.com
EMAIL_PASSWORD=test-password
EMAIL_FROM=test@inventory.com

# File Upload
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001

# Pagination
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=50

# Business Logic
INVOICE_NUMBER_PREFIX=TEST-INV
EXPENSE_NUMBER_PREFIX=TEST-EXP
TRIAL_PERIOD_DAYS=7
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
VIP_THRESHOLD=500
LOW_STOCK_THRESHOLD_PERCENTAGE=20

# Timezone
TIMEZONE=UTC

# Feature Flags (Disabled for tests unless specifically testing)
ENABLE_SUBSCRIPTION_CHECKS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_AUDIT_LOGS=false
ENABLE_ADVANCED_REPORTING=false

# Development Tools
DEBUG=false
LOG_API_REQUESTS=false
LOG_SQL_QUERIES=false
ENABLE_PERFORMANCE_MONITORING=false
