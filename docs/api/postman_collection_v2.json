                  "pm.test(\"User has correct company\", () => {",
                  "    const user = pm.response.json().data;",
                  "    const companyId = pm.environment.get(\"company_id_a\");",
                  "    pm.expect(user.company_id).to.eql(companyId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
