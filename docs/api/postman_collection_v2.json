    {
      "name": "7. Multi-Tenant Isolation",
      "item": [
        {
          "name": "7.1 Register Company B",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "    pm.environment.set(\"access_token_b\", res.data.token);",
                  "    pm.environment.set(\"company_id_b\", res.data.company.id);",
                  "    console.log(\"✅ Company B tokens saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"admin@companyb.com\",\n  \"password\": \"SecurePass456!\",\n  \"companyName\": \"Company B - Furniture\",\n  \"phone\": \"+0987654321\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "7.2 Create Product (Same Barcode)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token_b}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitor Samsung\",\n  \"barcode\": \"PROD-001\",\n  \"purchase_price\": 300,\n  \"selling_price\": 450,\n  \"current_stock\": 20\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            },
            "description": "Same barcode as Company A product - should succeed"
          }
        },
        {
          "name": "7.3 Test Cross-Company Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Returns 404\", () => pm.response.to.have.status(404));",
                  "pm.test(\"Generic error\", () => {",
                  "    const msg = pm.response.json().message;",
                  "    pm.expect(msg).to.include(\"not found\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token_b}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            },
            "description": "Company B trying to access Company A's product - should fail"
          }
        }
      ]
