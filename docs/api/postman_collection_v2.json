            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Supervisor\",\n  \"email\": \"alice@companya.com\",\n  \"password\": \"SupervisorPass123!\",\n  \"role\": \"supervisor\",\n  \"phone\": \"+1234567891\"\n}"
            },
            "url": {
