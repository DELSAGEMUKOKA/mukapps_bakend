{
  "info": {
    "name": "Inventory Management API - Complete Testing",
    "description": "Comprehensive API testing collection for multi-tenant inventory management system. Includes authentication, CRUD operations, multi-tenant isolation tests, and security validation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "inventory-api-v1"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token_a}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Register Company A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Has token\", () => pm.expect(pm.response.json().data.token).to.exist);",
                  "",
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "    pm.environment.set(\"access_token_a\", res.data.token);",
                  "    pm.environment.set(\"refresh_token_a\", res.data.refreshToken);",
                  "    pm.environment.set(\"user_id_a\", res.data.user.id);",
                  "    pm.environment.set(\"company_id_a\", res.data.company.id);",
                  "    console.log(\"✅ Company A tokens saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"admin@companya.com\",\n  \"password\": \"SecurePass123!\",\n  \"companyName\": \"Company A - Electronics Store\",\n  \"phone\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Creates first company with admin user and 14-day trial subscription"
          }
        },
        {
          "name": "1.2 Login Company A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "",
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "    pm.environment.set(\"access_token_a\", res.data.token);",
                  "    pm.environment.set(\"refresh_token_a\", res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@companya.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "1.3 Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "1.4 Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
